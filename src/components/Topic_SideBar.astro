---
interface Props {
    courseData : any,
    courseName : string
    courseSlug : string
}

const {courseData, courseName, courseSlug} = Astro.props;
let beginner :any[] = [];
let intermediate :any[] = [];
let advance :any[] = [];

if(courseData.length > 0){
beginner = courseData[0].topics.filter((topic :any )=>
topic.difficultyLevel === "Beginner"
)
intermediate = courseData[0].topics.filter((topic :any )=>
topic.difficultyLevel === "Intermediate"
)

advance = courseData[0].topics.filter((topic :any )=>
topic.difficultyLevel === "Advanced"
)
}

---

<!-- Mobile Sidebar Overlay + Drawer (for tablet/mobile) -->
<div id="mobileSidebarOverlay"
    class="mobile-sidebar-overlay fixed inset-0 bg-black/50 z-10 lg:hidden invisible opacity-0 transition-all duration-300">
</div>
<!-- lg:relative lg:h-auto -->
<aside id="mobileSidebar"
    class="fixed top-0 lg:top-20 left-0 z-10 h-full w-72 sm:w-80 bg-white dark:bg-gray-900 border-r border-gray-200 dark:border-gray-800 transform -translate-x-full transition-transform duration-300 ease-out lg:translate-x-0 lg:block lg:w-72 xl:w-80 flex-shrink-0 overflow-y-auto sidebar-scroll shadow-xl lg:shadow-none">
    <div
        class="sticky mt-16 lg:mt-0 top-0 bg-white dark:bg-gray-900 z-10 flex justify-between items-center p-4 border-b border-gray-200 dark:border-gray-800 lg:hidden">
        <div class="flex items-center gap-2">
            <i class="fab fa-js text-yellow-500"></i>
            <span class="font-semibold">Navigation</span>
        </div>
        <button id="closeSidebarBtn"
            class="w-8 h-8 rounded-full bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300">
            <i class="fas fa-times"></i>
        </button>
    </div>
    <div class="p-4 pb-8">
        <div class="mb-6">
            <h3
                class="text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-3 flex items-center gap-2">
                <i class="fas fa-compass"></i> Topics
            </h3>
            <div class="space-y-5">
                <!-- BEGINNER -->
                <div class="topic-group">
                    <div class="topic-toggle flex justify-between items-center cursor-pointer py-2 px-1 rounded-md hover:bg-gray-100 dark:hover:bg-gray-800/70 transition"
                        data-target="beginnerDropdown">
                        <div class="flex items-center gap-2">
                            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                            <span class="font-semibold">Beginner</span>
                            <span class="text-xs text-gray-500 dark:text-gray-400">(Fundamentals)</span>
                        </div>
                        <i class="fas fa-chevron-down text-gray-500 text-sm"></i>
                    </div>
                    <div id="beginnerDropdown" class="dropdown-submenu ml-4 mt-1 space-y-1">
                        {
                        (beginner.length > 0) &&
                        beginner.map((topic)=>(
                            <a href={`/CodeMastery/courses/${courseSlug}/${topic.slug}`}
                            class="block py-1.5 px-3 text-sm rounded-md hover:bg-gray-100 dark:hover:bg-gray-800"><i
                                class="fas fa-play-circle w-4 mr-2 text-emerald-500"></i>{topic.topicName}</a>
                            ))
                        }
                        
                    </div>
                </div>
                <!-- INTERMEDIATE -->
                <div class="topic-group">
                    <div class="topic-toggle flex justify-between items-center cursor-pointer py-2 px-1 rounded-md hover:bg-gray-100 dark:hover:bg-gray-800/70 transition"
                        data-target="intermediateDropdown">
                        <div class="flex items-center gap-2"><span
                                class="w-1.5 h-1.5 rounded-full bg-blue-500"></span><span
                                class="font-semibold">Intermediate</span><span
                                class="text-xs text-gray-500">(Core Mastery)</span></div>
                        <i class="fas fa-chevron-down text-gray-500 text-sm"></i>
                    </div>
                    <div id="intermediateDropdown" class="dropdown-submenu ml-4 mt-1 space-y-1">
                        {
                        (intermediate.length > 0) &&
                        intermediate.map((topic)=>(
                            <a href={`/CodeMastery/courses/${courseSlug}/${topic.slug}`}
                            class="block py-1.5 px-3 text-sm rounded-md hover:bg-gray-100 dark:hover:bg-gray-800"><i
                                class="fas fa-play-circle w-4 mr-2 text-blue-400"></i>{topic.topicName}</a>
                            ))
                        }
                    </div>
                </div>
                <!-- ADVANCED -->
                <div class="topic-group">
                    <div class="topic-toggle flex justify-between items-center cursor-pointer py-2 px-1 rounded-md hover:bg-gray-100 dark:hover:bg-gray-800/70 transition"
                        data-target="advancedDropdown">
                        <div class="flex items-center gap-2"><span
                                class="w-1.5 h-1.5 rounded-full bg-purple-500"></span><span
                                class="font-semibold">Advanced</span><span
                                class="text-xs text-gray-500">(Expert)</span></div>
                        <i class="fas fa-chevron-down text-gray-500 text-sm"></i>
                    </div>
                    <div id="advancedDropdown" class="dropdown-submenu ml-4 mt-1 space-y-1">
                        {
                        (advance.length > 0) &&
                        advance.map((topic)=>(
                            <a href={`/CodeMastery/courses/${courseSlug}/${topic.slug}`}
                            class="block py-1.5 px-3 text-sm rounded-md hover:bg-gray-100 dark:hover:bg-gray-800"><i
                                class="fas fa-play-circle w-4 mr-2 text-purple-400"></i>{topic.topicName}</a>
                            ))
                        }
                    </div>
                </div>
                <div class="pt-4 border-t border-gray-200 dark:border-gray-800 mt-2">
                    <div class="text-xs text-gray-500 dark:text-gray-400 px-1"><i
                            class="fas fa-book-open mr-1"></i> Resources</div>
                    <div class="mt-2 space-y-1">
                        <a href="#" class="flex items-center gap-2 text-sm px-3 py-1.5 rounded-md hover:bg-gray-100 dark:hover:bg-gray-800">
                            <i class="fas fa-download"></i>
                            Interview Questions
                        </a>
                        <a href="#" class="flex items-center gap-2 text-sm px-3 py-1.5 rounded-md hover:bg-gray-100 dark:hover:bg-gray-800"><i
                            class="fas fa-tasks"></i>
                            Quizzes
                        </a>
                        <a href="#" class="flex items-center gap-2 text-sm px-3 py-1.5 rounded-md hover:bg-gray-100 dark:hover:bg-gray-800"><i
                            class="fas fa-tasks"></i>
                            Project Ideas
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</aside>