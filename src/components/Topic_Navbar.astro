---
interface Props {
    courseTitle : string,
    courseSlug : string,
    courseImage : string,
}

const {courseTitle, courseImage, courseSlug} = Astro.props;
---

<!-- Header with mobile menu button + dark mode -->
<header
    class="sticky top-0 z-40 bg-white/95 dark:bg-gray-900/95 backdrop-blur-sm border-b border-gray-200 dark:border-gray-800 shadow-sm">
    <div class="px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center py-3 md:py-4">
            <div class="flex items-center gap-3">
                <!-- Mobile menu button (visible on tablet & mobile) -->
                <button id="mobileMenuBtn"
                    class="lg:hidden flex items-center justify-center w-9 h-9 rounded-lg bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700 transition">
                    <i class="fas fa-bars text-lg"></i>
                </button>
                <div class="flex items-center space-x-2">
                    <a class="hidden lg:block" href="/CodeMastery"><i class="fa-solid fa-house gradient-text text-2xl"></i></a>
                    <i class="hidden! lg:block! fa-solid fa-angle-right text-black dark:text-white "></i>
                    <a class="hidden lg:block" href="/CodeMastery/courses/"><span>Course</span></a>
                    <i class="hidden! lg:block! fa-solid fa-angle-right text-black dark:text-white "></i>
                    <a href={"/CodeMastery/courses/"+courseSlug} class="flex items-center space-x-2">
                        <img src={`/CodeMastery/_image?href=https://secureurl.github.io/cloud/OpenDevDocs/course-logo/${courseImage}.png&w=24&h=24&q=80&f=webp`} class="size-6" alt="">
                        <span class="font-bold text-xl tracking-tight bg-linear-to-r from-yellow-600 to-orange-500 bg-clip-text text-transparent dark:from-yellow-400 dark:to-orange-400">{courseTitle + " Mastery Docs" }</span>
                        {
                            false && 
                            <span class="hidden sm:inline-block ml-1 text-xs bg-gray-200 dark:bg-gray-800 px-2 py-0.5 rounded-full text-gray-600 dark:text-gray-400">v2.0</span>
                        }
                    </a>
                </div>
            </div>
            <div class="flex items-center gap-2 sm:gap-3">
                <button id="darkModeToggle"
                    class="size-10 p-2 rounded-full bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700 transition">
                    <i id="darkIcon" class="fas fa-sun"></i>
                </button>
                {
                    false &&
                    <div
                        class="hidden md:flex text-sm items-center gap-2 bg-gray-100 dark:bg-gray-800 px-3 py-1.5 rounded-full">
                        <i class="fas fa-search text-gray-500 text-xs"></i>
                        <span class="text-gray-500 dark:text-gray-400 text-xs">Ctrl + K</span>
                    </div>
                }
            </div>
        </div>
    </div>
</header>