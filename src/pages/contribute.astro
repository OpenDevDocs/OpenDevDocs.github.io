                    </div>
                </form>
                
                <!-- Success Message -->
                <div id="success-message" class="hidden text-center py-12">
                    <div class="w-24 h-24 gradient-bg rounded-full flex items-center justify-center mx-auto mb-6 scale-in">
                        <i class="fas fa-check text-white text-4xl"></i>
                    </div>
                    <h3 class="text-3xl font-bold mb-4">Welcome to the Team! 🎉</h3>
                    <p class="text-gray-600 dark:text-gray-300 text-lg max-w-2xl mx-auto mb-6">
                        Thank you for applying to become a {getSiteName()} contributor. Our editorial team will 
                        review your application and get back to you within 48 hours.
                    </p>
